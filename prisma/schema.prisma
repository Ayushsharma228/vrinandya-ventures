generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  SELLER
  SUPPLIER
  SALES
}

enum SalesStage {
  LEAD
  CALL_NOT_PICKED
  BUSY
  SCHEDULE_MEETING
  NOT_INTERESTED
  PROSPECT
  INTERESTED
  WILL_PAY
  PAID
  ONBOARDED
  WEBSITE_DONE
  ENGAGEMENT_LIVE
  ADS_LIVE
}

// AI SDR pipeline stages
enum PipelineStage {
  NEW_LEAD
  AI_CONTACT_PENDING
  AI_CONVERSATION_STARTED
  QUALIFICATION_COMPLETED
  HOT_LEAD
  WARM_LEAD
  COLD_LEAD
  SALES_CALL_SCHEDULED
  SALES_CALL_COMPLETED
  PROPOSAL_SENT
  PAYMENT_PENDING
  CLIENT
}

enum LeadTemperature {
  HOT
  WARM
  COLD
}

enum AiConvStatus {
  PENDING
  ACTIVE
  COMPLETED
  FAILED
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  DONE
  CANCELLED
}

enum Plan {
  DROPSHIPPING
  MARKETPLACE
}

enum AccountStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum KycStatus {
  NOT_SUBMITTED
  SUBMITTED
  APPROVED
  REJECTED
}

enum ProductStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ListingStatus {
  PENDING
  IN_PROGRESS
  LISTED
  FAILED
}

enum OrderStatus {
  NEW
  PROCESSING
  SHIPPED
  IN_TRANSIT
  DELIVERED
  CANCELLED
  RTO
}

enum OrderSource {
  SHOPIFY
  AMAZON
  FLIPKART
  MEESHO
  EBAY
  ETSY
  WALMART
  OTHER
}

enum NotificationType {
  PRODUCT_APPROVED
  PRODUCT_REJECTED
  LISTING_REQUEST
  LISTING_DONE
  ORDER_UPDATE
  AWB_GENERATED
  GENERAL
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  password      String
  role          Role      @default(SELLER)
  plan          Plan?
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  phone       String?
  brandName   String?
  gstNumber   String?
  bankHolder  String?
  bankAccount String?
  bankIfsc    String?
  bankName    String?

  // Signup & onboarding
  username             String?       @unique
  accountStatus        AccountStatus @default(ACTIVE)
  planTier             String?
  onboardingDone       Boolean       @default(false)

  // Business / invoice details
  businessName         String?
  businessAddress      String?
  pincode              String?

  // KYC
  aadhaarNumber        String?
  aadhaarDocUrl        String?
  kycStatus            KycStatus     @default(NOT_SUBMITTED)

  // Agreement
  agreementAccepted    Boolean       @default(false)
  agreementAcceptedAt  DateTime?

  // Payment
  paymentReference     String?
  paymentConfirmed     Boolean       @default(false)

  // Data visibility — orders before this date are hidden from seller dashboard
  dataStartDate        DateTime?

  // Sales team
  salesTarget          Int?
  salesTitle           String?

  organizationId      String?
  organization        Organization?       @relation(fields: [organizationId], references: [id])

  shopifyStore        ShopifyStore?
  marketplaceAccounts MarketplaceAccount[]
  orders              Order[]              @relation("SellerOrders")
  listingRequests     ListingRequest[]
  notifications       Notification[]
  suppliedProducts    Product[]
  warehouses          Warehouse[]
  remittances         Remittance[]
  walletTransactions  WalletTransaction[]
  adSpends            AdSpend[]
  settlements         Settlement[]
  assignedLeads       Lead[]               @relation("AssignedLeads")
  createdLeads        Lead[]               @relation("CreatedLeads")
  leadActivities      LeadActivity[]
  assignedTasks       Task[]               @relation("AssignedTasks")
  createdTasks        Task[]               @relation("CreatedTasks")
  assignedEvents      CalendarEvent[]      @relation("AssignedEvents")
  createdEvents       CalendarEvent[]      @relation("CreatedEvents")
  // Supplier fulfillment relations
  supplierOrders           Order[]              @relation("SupplierOrders")
  purchaseOrdersAsSupplier PurchaseOrder[]      @relation("SupplierPOs")
  purchaseOrdersAsSeller   PurchaseOrder[]      @relation("SellerPOs")
  supplierInventory        InventoryItem[]      @relation("SupplierInventory")
  supplierTransactions     SupplierTransaction[] @relation("SupplierTransactions")
  shippingProviders        SupplierShippingProvider[]
  supplierPayments         SupplierPayment[]            @relation("SupplierPayments")
  reconciliationReports    ReconciliationReport[]       @relation("ReconciliationReports")

  @@map("users")
}

model SupplierShippingProvider {
  id         String   @id @default(cuid())
  supplierId String
  supplier   User     @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  provider   String   // SHIPROCKET | DELHIVERY | CUSTOM
  label      String
  apiKey     String?
  apiSecret  String?
  baseUrl    String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("supplier_shipping_providers")
}

model Lead {
  id           String      @id @default(cuid())
  name         String
  email        String?
  phone        String
  city         String?
  investment   Float?
  source       String      @default("META_ADS")
  stage        SalesStage  @default(LEAD)
  isNI         Boolean     @default(false)
  followUpDate DateTime?
  notes        String?
  metaLeadId   String?     @unique
  assignedToId   String?
  assignedTo     User?       @relation("AssignedLeads", fields: [assignedToId], references: [id])
  createdById    String
  createdBy      User        @relation("CreatedLeads", fields: [createdById], references: [id])
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  activities     LeadActivity[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  // AI SDR fields
  pipelineStage        PipelineStage   @default(NEW_LEAD)
  temperature          LeadTemperature?
  leadScore            Int?
  aiStatus             AiConvStatus    @default(PENDING)

  // Meta form fields
  businessStage        String?
  budget               String?
  timeline             String?
  marketplace          String?
  biggestChallenge     String?
  campaign             String?
  adSet                String?

  // AI qualification output
  qualificationSummary String?
  recommendedPlan      String?
  salesCallBookedAt    DateTime?
  salesCallNotes       String?

  // Relations
  aiConversations      AiConversation[]
  tasks                Task[]
  scoreDetail          LeadScoreDetail?
  calendarEvents       CalendarEvent[]

  @@map("leads")
}

model LeadActivity {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String
  content   String?
  createdAt DateTime @default(now())

  @@map("lead_activities")
}

// ── AI SDR models ────────────────────────────────────────────────────────────

model AiConversation {
  id          String       @id @default(cuid())
  leadId      String
  lead        Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  status      AiConvStatus @default(PENDING)
  channel     String       @default("WHATSAPP") // WHATSAPP | WEB
  summary     String?      // AI-generated summary at end of conversation
  messages    AiMessage[]
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("ai_conversations")
}

model AiMessage {
  id             String         @id @default(cuid())
  conversationId String
  conversation   AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String         // "user" | "assistant"
  content        String
  whatsappMsgId  String?        // Meta WhatsApp message ID
  createdAt      DateTime       @default(now())

  @@map("ai_messages")
}

model LeadScoreDetail {
  id                 String   @id @default(cuid())
  leadId             String   @unique
  lead               Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  totalScore         Int      @default(0)        // 0–100
  budgetScore        Int      @default(0)        // 0–20
  timelineScore      Int      @default(0)        // 0–15
  experienceScore    Int      @default(0)        // 0–15
  decisionMakerScore Int      @default(0)        // 0–15
  marketplaceScore   Int      @default(0)        // 0–10
  goalScore          Int      @default(0)        // 0–10
  urgencyScore       Int      @default(0)        // 0–10
  buyingIntentScore  Int      @default(0)        // 0–5
  scoredAt           DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("lead_score_details")
}

model Task {
  id           String     @id @default(cuid())
  leadId       String?
  lead         Lead?      @relation(fields: [leadId], references: [id], onDelete: SetNull)
  assignedToId String?
  assignedTo   User?      @relation("AssignedTasks", fields: [assignedToId], references: [id])
  createdById  String
  createdBy    User       @relation("CreatedTasks", fields: [createdById], references: [id])
  title        String
  description  String?
  status       TaskStatus @default(PENDING)
  dueDate      DateTime?
  completedAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@map("tasks")
}

model KnowledgeBase {
  id        String   @id @default(cuid())
  category  String   // e.g. "pricing", "rto", "fulfilment"
  question  String
  answer    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("knowledge_base")
}

model CalendarEvent {
  id           String    @id @default(cuid())
  leadId       String?
  lead         Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  assignedToId String?
  assignedTo   User?     @relation("AssignedEvents", fields: [assignedToId], references: [id])
  createdById  String
  createdBy    User      @relation("CreatedEvents", fields: [createdById], references: [id])
  title        String
  description  String?
  startAt      DateTime
  endAt        DateTime
  meetingLink  String?
  status       String    @default("SCHEDULED") // SCHEDULED | COMPLETED | CANCELLED
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("calendar_events")
}

enum WalletTxType {
  CREDIT
  DEBIT
}

enum SupplierOrderStatus {
  PENDING_ASSIGNMENT
  ASSIGNED
  ACCEPTED
  REJECTED
  PROCESSING
  PACKED
  READY_TO_SHIP
  DISPATCHED
}

enum PurchaseOrderStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  PROCESSING
  PACKED
  DISPATCHED
  DELIVERED
  CANCELLED
}

enum SupplierTxType {
  CREDIT
  DEBIT
  HOLD
  RELEASE
}

enum SettlementStatus {
  PENDING
  PROCESSING
  SETTLED
  DISPUTED
}

enum LedgerEntryType {
  ORDER_DELIVERED
  SETTLEMENT_GENERATED
  WALLET_CREDITED
  WALLET_DEBITED
  SUPPLIER_PAYMENT_PENDING
  SUPPLIER_PAYMENT_PAID
  SELLER_PAYOUT
  RTO_CHARGE
  REFUND
  ADJUSTMENT
  AD_SPEND
  PLATFORM_FEE
}

enum LedgerDirection {
  CREDIT
  DEBIT
}

enum SupplierPaymentStatus {
  PENDING
  APPROVED
  PAID
  CANCELLED
}

model AdSpend {
  id        String   @id @default(cuid())
  sellerId  String
  seller    User     @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  date      DateTime
  amount    Float
  note      String?
  createdAt DateTime @default(now())

  @@map("ad_spends")
}

model WalletTransaction {
  id              String       @id @default(cuid())
  sellerId        String
  seller          User         @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  type            WalletTxType
  amount          Float
  note            String?
  orderId         String?
  settlementId    String?      // links back to Settlement that generated this tx
  remittanceDate  DateTime?
  bankTxId        String?
  createdAt       DateTime     @default(now())

  @@map("wallet_transactions")
}

model ShopifyStore {
  id           String   @id @default(cuid())
  sellerId     String   @unique
  seller       User     @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  storeName    String
  storeUrl     String
  accessToken  String
  clientId     String?
  clientSecret String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("shopify_stores")
}

model MarketplaceAccount {
  id          String      @id @default(cuid())
  sellerId    String
  seller      User        @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  platform    OrderSource
  credentials Json
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([sellerId, platform])
  @@map("marketplace_accounts")
}

model Product {
  id          String        @id @default(cuid())
  supplierId     String
  supplier       User          @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  name           String
  description    String?
  price          Float
  stock          Int           @default(0)
  images         String[]
  category       String?
  sku            String?       @unique
  status         ProductStatus @default(PENDING)
  adminNote      String?
  // Enhanced supplier product fields
  costPrice      Float?
  suggestedPrice Float?
  weight         Float?
  length         Float?
  width          Float?
  height         Float?
  moq            Int?
  hsn            String?
  gstRate        Float?
  videoUrls      String[]
  documents      Json?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  listingRequests ListingRequest[]
  orderItems      OrderItem[]
  inventory       InventoryItem?
  variants        ProductVariant[]

  @@map("products")
}

model ListingRequest {
  id        String        @id @default(cuid())
  sellerId  String
  seller    User          @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  productId String
  product   Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  platform  OrderSource
  status    ListingStatus @default(PENDING)
  adminNote String?
  listedUrl String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@map("listing_requests")
}

model Order {
  id              String       @id @default(cuid())
  sellerId        String
  seller          User         @relation("SellerOrders", fields: [sellerId], references: [id], onDelete: Cascade)
  organizationId  String?
  organization    Organization? @relation(fields: [organizationId], references: [id])
  externalOrderId String
  source          OrderSource
  status          OrderStatus  @default(NEW)
  customerName    String?
  customerEmail   String?
  customerAddress Json?
  totalAmount     Float
  currency        String       @default("INR")
  awbNumber       String?
  trackingUrl     String?
  courier         String?
  rawData         Json?
  productCost     Float?
  shippingCharge  Float?
  packingCharge   Float?
  rtoCharge       Float?
  remittedAt      DateTime?
  remittanceTxId  String?
  ndrReason       String?
  ndrStatus       String?
  ndrAttempts     Int          @default(0)
  ndrActionTaken  String?
  // Supplier fulfillment fields
  supplierId           String?
  supplier             User?                @relation("SupplierOrders", fields: [supplierId], references: [id])
  supplierStatus       SupplierOrderStatus?
  supplierNote         String?
  expectedDispatchDate DateTime?
  expectedDeliveryDate DateTime?
  dispatchedAt         DateTime?
  supplierTrackingNo   String?
  supplierCourier      String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  items            OrderItem[]
  purchaseOrder    PurchaseOrder?
  timeline         OrderTimeline[]
  supplierPayment  SupplierPayment?

  @@unique([sellerId, externalOrderId, source])
  @@map("orders")
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String?
  product   Product? @relation(fields: [productId], references: [id])
  name      String
  sku       String?
  quantity  Int
  price     Float

  @@map("order_items")
}

enum WarehouseStatus {
  PENDING
  APPROVED
  REJECTED
}

enum WarehousePanel {
  PANEL_1
  PANEL_2
  BOTH
}

model Warehouse {
  id            String          @id @default(cuid())
  supplierId    String
  supplier      User            @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  name          String
  contactName   String
  phone         String
  addressLine1  String
  addressLine2  String?
  pincode       String
  city          String
  state         String
  email         String?
  targetPanel   WarehousePanel  @default(BOTH)
  status        WarehouseStatus @default(PENDING)
  adminNote     String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@map("warehouses")
}

model Remittance {
  id          String   @id @default(cuid())
  supplierId  String
  supplier    User     @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  amount      Float
  note        String?
  orderId     String?
  createdAt   DateTime @default(now())

  @@map("remittances")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  data      Json?
  createdAt DateTime         @default(now())

  @@map("notifications")
}

// ── Platform Configuration ────────────────────────────────────────────────────
// Key-value store for admin-editable platform settings (return address, fees, etc.)
model PlatformConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  label     String?
  updatedAt DateTime @updatedAt

  @@map("platform_configs")
}

// ── Settlement ────────────────────────────────────────────────────────────────
// Structured per-order settlement record (replaces free-text wallet notes)
model Settlement {
  id               String           @id @default(cuid())
  orderId          String           @unique
  sellerId         String
  seller           User             @relation(fields: [sellerId], references: [id])
  supplierId       String?          // supplier involved in this order
  marketplace      String?          // SHOPIFY | AMAZON | FLIPKART | MEESHO
  sellingPrice     Float
  productCost      Float            @default(0)
  shippingCharge   Float            @default(0)
  packingCharge    Float            @default(0)
  platformFee      Float            @default(0)
  codFee           Float            @default(0)
  rtoCharge        Float            @default(0)
  otherDeductions  Float            @default(0)
  marketplaceFee   Float            @default(0)  // Amazon/Flipkart platform cut
  gstOnFees        Float            @default(0)  // 18% GST on platform commission
  adSpend          Float            @default(0)  // attributed advertising cost
  grossProfit      Float?           // sellingPrice - productCost
  netProfit        Float?           // grossProfit minus all fees
  netPayable       Float            // what seller receives (= sellerEarnings)
  platformEarnings Float?           // platformFee - gstOnFees
  supplierPayable  Float?           // productCost owed to supplier
  status           SettlementStatus @default(PENDING)
  settledAt        DateTime?
  walletTxId       String?
  notes            String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@map("settlements")
}

// ── Ledger (immutable financial event log) ────────────────────────────────────
model LedgerEntry {
  id            String          @id @default(cuid())
  entryType     LedgerEntryType
  direction     LedgerDirection
  entityId      String          // sellerId, supplierId, or "PLATFORM"
  entityType    String          // SELLER | SUPPLIER | PLATFORM
  amount        Float
  referenceId   String?         // orderId, settlementId, walletTxId
  referenceType String?         // ORDER | SETTLEMENT | WALLET_TX | SUPPLIER_PAYMENT
  description   String
  metadata      Json?
  createdAt     DateTime        @default(now())

  @@index([entityId])
  @@index([referenceId])
  @@map("ledger_entries")
}

// ── Supplier Payment (what AXQEN owes supplier per dispatched order) ──────────
model SupplierPayment {
  id          String                @id @default(cuid())
  supplierId  String
  supplier    User                  @relation("SupplierPayments", fields: [supplierId], references: [id])
  orderId     String                @unique
  order       Order                 @relation(fields: [orderId], references: [id])
  amount      Float
  status      SupplierPaymentStatus @default(PENDING)
  dueDate     DateTime?
  paidAt      DateTime?
  referenceNo String?
  bankTxId    String?
  invoiceNo   String?
  notes       String?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@map("supplier_payments")
}

// ── Organization ──────────────────────────────────────────────────────────────
// Multi-tenancy foundation. Vrinandya Ventures is org 1.
model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users    User[]
  leads    Lead[]
  orders   Order[]
  products Product[]

  @@map("organizations")
}

// ── Supplier Fulfillment Engine ───────────────────────────────────────────────

model PurchaseOrder {
  id                   String              @id @default(cuid())
  poNumber             String              @unique
  orderId              String              @unique
  order                Order               @relation(fields: [orderId], references: [id])
  supplierId           String
  supplier             User                @relation("SupplierPOs", fields: [supplierId], references: [id])
  sellerId             String
  seller               User                @relation("SellerPOs", fields: [sellerId], references: [id])
  status               PurchaseOrderStatus @default(DRAFT)
  supplierCost         Float               @default(0)
  sellingPrice         Float               @default(0)
  expectedDispatchDate DateTime?
  expectedDeliveryDate DateTime?
  rejectionReason      String?
  dispatchedAt         DateTime?
  notes                String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  items                PurchaseOrderItem[]

  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  productId       String?
  name            String
  sku             String?
  quantity        Int
  unitCost        Float         @default(0)

  @@map("purchase_order_items")
}

model OrderTimeline {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  actorId   String?
  actorRole String?
  event     String
  details   String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@map("order_timeline")
}

model InventoryItem {
  id                String   @id @default(cuid())
  productId         String   @unique
  product           Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  supplierId        String
  supplier          User     @relation("SupplierInventory", fields: [supplierId], references: [id])
  availableQty      Int      @default(0)
  reservedQty       Int      @default(0)
  incomingQty       Int      @default(0)
  lowStockThreshold Int      @default(5)
  updatedAt         DateTime @updatedAt

  @@map("inventory_items")
}

model SupplierTransaction {
  id         String         @id @default(cuid())
  supplierId String
  supplier   User           @relation("SupplierTransactions", fields: [supplierId], references: [id])
  type       SupplierTxType
  amount     Float
  note       String?
  orderId    String?
  poId       String?
  settledAt  DateTime?
  createdAt  DateTime       @default(now())

  @@map("supplier_transactions")
}

// ── Reconciliation Engine ─────────────────────────────────────────────────────

enum ReconciliationStatus {
  UPLOADED
  PROCESSING
  COMPLETED
  FAILED
}

enum ReconciliationEntryStatus {
  PENDING
  MATCHED
  UNMATCHED
  DISCREPANCY
  SETTLED
}

model ReconciliationReport {
  id              String               @id @default(cuid())
  uploadedById    String
  uploadedBy      User                 @relation("ReconciliationReports", fields: [uploadedById], references: [id])
  marketplace     String               // AMAZON | FLIPKART | MEESHO
  filename        String
  dateFrom        DateTime?
  dateTo          DateTime?
  status          ReconciliationStatus @default(UPLOADED)
  totalRows       Int                  @default(0)
  matchedRows     Int                  @default(0)
  unmatchedRows   Int                  @default(0)
  discrepancyRows Int                  @default(0)
  settledRows     Int                  @default(0)
  errorMessage    String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  entries ReconciliationEntry[]

  @@map("reconciliation_reports")
}

model ReconciliationEntry {
  id                 String                    @id @default(cuid())
  reportId           String
  report             ReconciliationReport      @relation(fields: [reportId], references: [id], onDelete: Cascade)
  marketplaceOrderId String
  orderId            String?
  sellerId           String?
  marketplace        String
  grossAmount        Float                     @default(0)
  marketplaceFee     Float                     @default(0)
  tds                Float                     @default(0)
  shippingFee        Float                     @default(0)
  netAmount          Float                     @default(0)
  ourNetPayable      Float?
  discrepancyAmount  Float?
  status             ReconciliationEntryStatus @default(PENDING)
  discrepancyReason  String?
  settlementId       String?
  rawData            Json?
  createdAt          DateTime                  @default(now())

  @@index([reportId])
  @@index([orderId])
  @@map("reconciliation_entries")
}

model ProductVariant {
  id         String   @id @default(cuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name       String
  sku        String?  @unique
  price      Float
  stock      Int      @default(0)
  attributes Json?
  images     String[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("product_variants")
}

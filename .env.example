# ─────────────────────────────────────────────────────────────────────────────
# AXQEN — Environment Variables Reference
# Copy this file to .env and fill in your values.
# Never commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# ── NextAuth ──────────────────────────────────────────────────────────────────
NEXTAUTH_URL="https://yourdomain.com"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
ADMIN_EMAIL="connect@vrinandyaventures.in"

# ── Image Uploads (Cloudinary) ────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# ── Shopify (Platform App Credentials) ───────────────────────────────────────
# These are the default app credentials. Sellers can override with their own.
SHOPIFY_API_KEY="your_shopify_api_key"
SHOPIFY_API_SECRET="your_shopify_api_secret"

# ── Delhivery (Courier / AWB) ─────────────────────────────────────────────────
DELHIVERY_API_TOKEN="your_delhivery_api_token"
DELHIVERY_PICKUP_LOCATION="SELF"

# ── Return / Seller Address (used in AWB shipment creation) ──────────────────
RETURN_NAME="Your Name"
RETURN_ADDRESS="Your Street Address"
RETURN_CITY="Your City"
RETURN_STATE="Your State"
RETURN_PINCODE="000000"
RETURN_PHONE="9999999999"

# ── Meta Lead Ads ─────────────────────────────────────────────────────────────
# Use a never-expiring Page Access Token (see docs/meta-token-setup.md)
META_PAGE_TOKEN="your_meta_page_access_token"

# ── CJ Dropshipping ───────────────────────────────────────────────────────────
CJ_EMAIL="your_cj_account_email"
CJ_API_KEY="your_cj_api_key"

# ── AI (Anthropic Claude) ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-xxxxxxxxxxxxxxxxxxxx"

# ── Cron Job Security ─────────────────────────────────────────────────────────
# Used to authenticate internal cron job requests
CRON_SECRET="generate-with: openssl rand -hex 32"
